# Force LF line endings for all text files
* text=auto eol=lf

# Patterns and language data (auto-generated)
data/patterns/*.txt linguist-generated=true
data/languages/*.json linguist-generated=true

# Build artifacts
/build/ export-ignore
/cache/ export-ignore

# Tools
/tools/ export-ignore

# Tests
/tests/ export-ignore
/phpunit.xml export-ignore
/phpstan.neon export-ignore
/.php-cs-fixer.php export-ignore
/infection.json5 export-ignore

# Dev
/.gitignore export-ignore
/.gitattributes export-ignore
/.editorconfig export-ignore
