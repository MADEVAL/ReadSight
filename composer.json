{
    "name": "globus-studio/readsight",
    "description": "Multilingual readability library for PHP — 86 languages, 17 formulas, TeX-based syllable counting via Frank M. Liang algorithm. Zero dependencies.",
    "type": "library",
    "keywords": [
        "readability",
        "syllable",
        "hyphenation",
        "flesch-kincaid",
        "gunning-fog",
        "smog",
        "coleman-liau",
        "ari",
        "lix",
        "gulpease",
        "wiener-sachtextformel",
        "multilingual",
        "tex",
        "liang"
    ],
    "homepage": "https://github.com/MADEVAL/ReadSight",
    "license": "MIT",
    "authors": [
        {
            "name": "Yevhen Leonidov",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/MADEVAL/ReadSight/issues",
        "source": "https://github.com/MADEVAL/ReadSight"
    },
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "*",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "GlobusStudio\\ReadSight\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GlobusStudio\\ReadSight\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html=build/coverage",
        "analyse": "php -d memory_limit=512M vendor/bin/phpstan analyse --memory-limit=256M",
        "cs:check": "php-cs-fixer check",
        "cs:fix": "php-cs-fixer fix",
        "check": [
            "@cs:check",
            "@analyse",
            "@test"
        ]
    }
}
